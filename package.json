{
  "name": "pstn-analytics",
  "version": "0.2.0",
  "private": true,
  "author": "Finenumbers <apps@finenumbers.com>",
  "homepage": "https://github.com/finenumbers/pstn#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/finenumbers/pstn.git"
  },
  "bugs": {
    "url": "https://github.com/finenumbers/pstn/issues",
    "email": "apps@finenumbers.com"
  },
  "scripts": {
    "dev": "next dev --turbopack -p 5555",
    "build": "next build",
    "start": "next start -p 5555",
    "lint": "eslint . --max-warnings 0",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:explain-phone-search": "tsx scripts/explain-phone-search.ts",
    "db:rebuild-dicts": "tsx scripts/rebuild-dictionaries.ts",
    "db:push": "drizzle-kit push",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "audit": "npm audit --audit-level=high",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f app",
    "docker:dev-db": "docker compose -f docker-compose.dev.yml up -d",
    "docker:prod": "docker compose -f docker-compose.prod.yml up -d --build",
    "docker:prod:down": "docker compose -f docker-compose.prod.yml down",
    "docker:prod:logs": "docker compose -f docker-compose.prod.yml logs -f app",
    "docker:portainer": "docker compose -f docker-compose.portainer.yml up -d --build"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-popover": "^1.1.6",
    "@radix-ui/react-slot": "^1.1.2",
    "@tanstack/react-query": "^5.67.1",
    "@tanstack/react-table": "^8.21.2",
    "@tanstack/react-virtual": "^3.14.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.4",
    "csv-parse": "^5.6.0",
    "drizzle-orm": "^0.45.2",
    "exceljs": "^4.4.0",
    "lucide-react": "^0.475.0",
    "next": "^15.2.0",
    "pg": "^8.13.3",
    "pino": "^9.6.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.0.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4.0.9",
    "@types/node": "^22.13.5",
    "@types/pg": "^8.11.11",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.21.0",
    "eslint-config-next": "^15.2.0",
    "tailwindcss": "^4.0.9",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.7"
  }
}
