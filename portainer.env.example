# Environment variables for Portainer (Stacks → Environment variables).
# Generate password: openssl rand -base64 32
#
# DATABASE_URL host must be "postgres" (Docker service name), not localhost.

POSTGRES_USER=pstn
POSTGRES_PASSWORD=change-me-use-a-strong-password
POSTGRES_DB=pstn

DATABASE_URL=postgresql://pstn:change-me-use-a-strong-password@postgres:5432/pstn

APP_PORT=5555
LOG_LEVEL=info
DB_POOL_MAX=10
DB_IMPORT_POOL_MAX=4

IMAGE_TAG=latest

# Optional: X-Import-Secret for POST /api/import. Leave empty for import via UI button.
# Prefer NPM Access List for site protection instead.
# IMPORT_SECRET=
