# Portainer stack env. See docs/deployment.md

POSTGRES_USER=pstn
POSTGRES_PASSWORD=change-me-use-a-strong-password
POSTGRES_DB=pstn
# DATABASE_URL is built automatically in the container from POSTGRES_* / DB_* — do not set unless overriding locally.

APP_PORT=5555
LOG_LEVEL=info
DB_POOL_MAX=10
DB_IMPORT_POOL_MAX=4

# Optional: EXTERNAL_API_BASE_URL=https://pstn.finenumbers.com
# Optional: OPR_CSV_PATH=/path/to/custom-opr.csv (default: bundled data/opr in image)
# EXTERNAL_API_KEY=your-fixed-key
# IMPORT_SECRET=
