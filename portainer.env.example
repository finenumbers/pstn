# Portainer stack env. See docs/deployment.md

POSTGRES_USER=pstn
POSTGRES_PASSWORD=change-me-use-a-strong-password
POSTGRES_DB=pstn
DATABASE_URL=postgresql://pstn:change-me-use-a-strong-password@postgres:5432/pstn

APP_PORT=5555
LOG_LEVEL=info
DB_POOL_MAX=10
DB_IMPORT_POOL_MAX=4
IMAGE_TAG=latest
# Git branch/tag for app image build (docker-compose.portainer.yml build context)
GIT_REF=main

# EXTERNAL_API_BASE_URL=https://pstn.example.com
# EXTERNAL_API_KEY=your-fixed-key
# IMPORT_SECRET=
