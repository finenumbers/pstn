# Portainer stack env. See docs/deployment.md
#
# Wired in docker-compose.portainer.yml today: POSTGRES_*, APP_PORT, LOG_LEVEL,
# DB_POOL_*, EXTERNAL_API_BASE_URL. The variables below marked [not wired] are
# documented for CLI prod / future compose changes — they do NOT reach the container
# unless you add them to docker-compose.portainer.yml.

POSTGRES_USER=pstn
POSTGRES_PASSWORD=change-me-use-a-strong-password
POSTGRES_DB=pstn
# DATABASE_URL is built automatically in the container from POSTGRES_* / DB_* — do not set unless overriding locally.

APP_PORT=5555
LOG_LEVEL=info
DB_POOL_MAX=10
DB_IMPORT_POOL_MAX=4

# Optional: EXTERNAL_API_BASE_URL=https://pstn.finenumbers.com
# [not wired] OPR_CSV_PATH=/path/to/custom-opr.csv — default: bundled data/opr in image
# [not wired] EXTERNAL_API_KEY=your-fixed-key — auto-generated in pstn_secrets volume if omitted
# [not wired] IMPORT_SECRET= — optional X-Import-Secret for POST /api/import
