# Локальная разработка (Next.js на хосте)
DATABASE_URL=postgresql://pstn:pstn@localhost:5432/pstn
LOG_LEVEL=info
PORT=5555
DB_POOL_MAX=10
DB_IMPORT_POOL_MAX=4

# Optional: require X-Import-Secret header on POST /api/import
# IMPORT_SECRET=change-me

# Docker Compose (app контейнер — хост postgres внутри сети compose)
# DATABASE_URL=postgresql://pstn:pstn@postgres:5432/pstn
# APP_PORT=5555
